---
import { site } from '../../data/site';
import ExternalLink from '../ui/ExternalLink.astro';
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__details">
      <p>© 2026 Nikita Glazkov</p>
      <p class="site-footer__technology">
        Built with Astro, TypeScript and vanilla CSS.
      </p>
    </div>
    <nav aria-label="Footer links">
      <ExternalLink
        href={site.contact.linkedin.url}
        label={site.contact.linkedin.label}
        ariaLabel={site.contact.linkedin.ariaLabel}
        variant="context"
        analyticsEvent="contact-click"
        analyticsData={{ channel: 'linkedin', placement: 'footer' }}
      />
      <a
        class="external-link external-link--context"
        href={`mailto:${site.contact.email}`}
        data-umami-event="contact-click"
        data-umami-event-channel="email"
        data-umami-event-placement="footer">Email</a
      >
      <ExternalLink
        href={site.contact.telegram.url}
        label={site.contact.telegram.label}
        ariaLabel={site.contact.telegram.ariaLabel}
        variant="context"
        analyticsEvent="contact-click"
        analyticsData={{ channel: 'telegram', placement: 'footer' }}
      />
    </nav>
  </div>
</footer>
