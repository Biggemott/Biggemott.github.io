---
import { expertiseGroups } from '../../data/experience';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section
  class="expertise section"
  id="expertise"
  aria-labelledby="expertise-heading"
>
  <SectionHeading
    eyebrow="Technical expertise"
    title="Deep Android foundations with modern product and multiplatform delivery"
    id="expertise-heading"
  />
  <p class="expertise__intro prose">
    My deepest expertise is in native Android engineering, supported by
    production experience across architecture, media, testing, platform
    development, Kotlin Multiplatform and technical leadership.
  </p>
  <div class="expertise__groups">
    {
      expertiseGroups.map((group) => (
        <article>
          <>
            <h3>{group.title}</h3>
            <ul>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </>
        </article>
      ))
    }
  </div>
</section>
