---
interface Props {
  href: string;
  label: string;
  ariaLabel: string;
  variant?: 'store' | 'context';
  analyticsEvent?: string;
  analyticsData?: Record<string, string>;
}

const {
  href,
  label,
  ariaLabel,
  variant = 'store',
  analyticsEvent,
  analyticsData = {},
} = Astro.props;
const analyticsAttributes = analyticsEvent
  ? {
      'data-umami-event': analyticsEvent,
      ...Object.fromEntries(
        Object.entries(analyticsData).map(([key, value]) => [
          `data-umami-event-${key}`,
          value,
        ]),
      ),
    }
  : {};
---

<a
  class:list={['external-link', `external-link--${variant}`]}
  href={href}
  target="_blank"
  rel="noreferrer noopener"
  aria-label={ariaLabel}
  {...analyticsAttributes}
>
  {label}<span class="external-link__indicator" aria-hidden="true">↗</span>
  <span class="sr-only"> (opens in a new tab)</span>
</a>
