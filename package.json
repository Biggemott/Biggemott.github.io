{
  "name": "biggemott.github.io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "visual:install": "playwright install chromium",
    "visual:capture": "npm run build && playwright test tests/visual/capture.spec.ts",
    "visual:test": "npm run build && playwright test tests/visual/smoke.spec.ts"
  },
  "dependencies": {
    "astro": "^7.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.3"
  }
}
